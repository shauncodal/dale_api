# Database: local MySQL only (no Docker). Create DB first, e.g.:
#   mysql -u root -e "CREATE DATABASE IF NOT EXISTS dale_lite_admin;"
# Never commit .env to version control.
DATABASE_URL="mysql://user:password@localhost:3306/dale_lite_admin"

# Server. Use 3002 when DaleAdminFrontend runs on 3001 so /api requests hit this server.
PORT=3002

# CORS origin for DaleAdminFrontend (where the app is served, e.g. port 3001 or 5173)
CORS_ORIGIN="http://localhost:3001"
# In development, localhost:3001, 8080, 3000, 5000, 5173 are allowed by default for Flutter/web.
# Override with comma-separated list, e.g. CORS_ORIGINS="http://localhost:3001,http://localhost:8080"

# Terms/Privacy consent document version — must match VITE_CONSENT_DOCUMENT_VERSION on frontends
CONSENT_DOCUMENT_VERSION="2025-03-26"

# Optional: GET /api/version metadata (set in CI/CD)
# API_VERSION=1.0.0
# GIT_SHA=
# GIT_BRANCH=
# GIT_COMMIT_MESSAGE=
# BUILD_DESCRIPTION=

# JWT signing secret for auth tokens
JWT_SECRET="change-me-in-production-min-32-chars"

# Lite Admin default user (dev/seed only). Change in production.
LITE_ADMIN_EMAIL="liteadmin@example.com"
LITE_ADMIN_PASSWORD="LiteAdminChangeMe1!"

# Optional: data residency / POPIA (e.g. "ZA" or region name for docs)
# DATA_RESIDENCY="ZA"

# Optional: session retention (e.g. days before soft-deleted sessions are purged)
# SESSION_RETENTION_DAYS=90

# Avatar image uploads. Directory for stored files (relative to app root). Subfolder "avatars" is used.
# UPLOAD_DIR=uploads
# Max file size in bytes (default 2MB).
# MAX_FILE_SIZE=2097152

# Invite email (MailerSend). If MAILERSEND_API_KEY or MAIL_FROM is not set, invite emails are no-op or logged only in dev.
# Production (EC2/ECS/CodeBuild): add MAILERSEND_API_KEY, MAIL_FROM, and optional MAIL_FROM_NAME to AWS Secrets Manager
# secret "dale/dev/secrets" — same keys as here — then redeploy the API so .env / task picks them up.
MAILERSEND_API_KEY=
# Sender address (must be a verified identity in MailerSend). Verified domain: dineonext.io
MAIL_FROM=invite@dineonext.io
# Optional: display name shown in inbox (e.g. "DALE Invite").
# MAIL_FROM_NAME=DALE Invite
# APP_URL or LOGIN_URL: base URL for login link in invite email (defaults to CORS_ORIGIN)
# APP_URL=http://localhost:3001
# LOGO_URL: full URL for logo in invite emails (e.g. https://api.example.com/logo.png). In dev, defaults to http://localhost:3002/logo.png

# MailerLite API token (optional). If set, new users are synced as subscribers.
# MAILERLITE_API_TOKEN=

# LiveAvatar API key for proxy (optional for public avatars, recommended for contexts). Used server-side.
# LIVEAVATAR_API_KEY=

# S3 for session recordings. Required for recording upload. Path: {tenantId}/{userId}/{coachId}/{sessionId}-{timestamp}.webm
# AWS_REGION=us-east-1
# S3_RECORDINGS_BUCKET=your-recordings-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
